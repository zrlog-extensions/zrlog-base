<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>zrlog-base</artifactId>
        <groupId>com.hibegin</groupId>
        <version>3.5.6-SNAPSHOT</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>
    <artifactId>zrlog-common</artifactId>
    <name>ZrLog Common</name>

    <dependencies>
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
        </dependency>
        <dependency>
            <groupId>com.hibegin</groupId>
            <artifactId>common-dao</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jsoup</groupId>
            <artifactId>jsoup</artifactId>
            <version>1.17.2</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <executions>
                    <execution>
                        <id>compile-java-21</id>
                        <phase>compile</phase>
                        <goals>
                            <goal>compile</goal>
                        </goals>
                        <configuration>
                            <release>21</release>
                            <compileSourceRoots>
                                <compileSourceRoot>${project.basedir}/src/main/java21</compileSourceRoot>
                            </compileSourceRoots>
                            <multiReleaseOutput>true</multiReleaseOutput>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.12</version>
                <configuration>
                    <excludes>
                        <exclude>META-INF/versions/**</exclude>
                        <!-- TODO cover external update/network/runtime boundaries with slower integration tests. -->
                        <exclude>com/zrlog/common/updater/**</exclude>
                        <exclude>com/hibegin/common/util/http/**</exclude>
                        <exclude>com/zrlog/common/hooks/TermSignalHandler.class</exclude>
                        <exclude>com/zrlog/common/resource/ZrLogResourceLoader.class</exclude>
                        <exclude>com/zrlog/util/DataSourceUtil.class</exclude>
                        <exclude>com/zrlog/util/DbUtils.class</exclude>
                        <exclude>com/zrlog/util/BlogBuildInfoUtil.class</exclude>
                        <exclude>com/zrlog/util/I18nUtil.class</exclude>
                        <exclude>com/zrlog/util/ZrLogBaseNativeImageUtils.class</exclude>
                        <exclude>com/zrlog/common/ZrLogConfig.class</exclude>
                        <exclude>com/zrlog/web/BaseWebSetup.class</exclude>
                        <exclude>com/zrlog/web/WebSetupContext.class</exclude>
                    </excludes>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
